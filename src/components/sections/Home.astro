---
import "/node_modules/@glidejs/glide/dist/css/glide.core.min.css";
import SlideGen from "../slideGen.astro";
import { slides_dat } from "../../data/slideDat";
import GhostSpacer from "./GhostSpacer.astro";
---

<!-- <div id="pageLabel">
  <div class="menuMessageBox mini">Welcome!</div>
</div> -->
<div class="herologo">
  <img src="/src/assets/mybpr.svg" alt="MyBPR Logo" />
</div>

<div class="heroGlide heroCarousel">
  <div class="glide__track" data-glide-el="track">
    <ul class="glide__slides">
      {
        Object.entries(slides_dat).map(([key, slide]) => (
          <SlideGen
            id={slide.id}
            title={slide.title}
            description={slide.description ?? ""}
            subcat={slide.subcat ?? undefined}
            images={slide.images}
            button={slide.button}
          />
        ))
      }
    </ul>
  </div>
  <div class="glide__bullets heroSlideBullets" data-glide-el="controls[nav]">
    {
      Object.entries(slides_dat).map(([key, slide], i) => (
        <button class="glide__bullet" data-glide-dir={`=${i}`}>
          <span class="heroBulletIndex">{i + 1}</span>
        </button>
      ))
    }
  </div>
</div>
<div class="centering">
  <div class="main">
    <div class="mbox" id="flowchart_kredit">
      <div class="kredit_stringbox">Alur Pengajuan Kredit</div>
      <div class="kredit_glide">
        <div class="glide__track" data-glide-el="track">
          <ul class="glide__slides">
            <li class="glide__slide kredit">
              <div class="ffpImageBox">
                <div
                  class="ffpImg"
                  style="background: url(/imgs/webview/ffp1.jpg) center/cover no-repeat;"
                >
                </div>
                <span class="ffpIco material-symbols-rounded">publish</span>
              </div>
              <div class="ffpStepLabel">01</div>
              <div class="ffpHeading">Step 1: Pengajuan Kredit</div>
              <div class="ffpTextBox">
                Pada tahap ini, debitur yang membutuhkan kredit mengajukan
                permohonan kredit ke MyBPR Debitur dapat melakukan pendaftaran
                secara online atau dengan mengisi formulir aplikasi.
              </div>
            </li>
            <li class="glide__slide kredit">
              <div class="ffpImageBox">
                <div
                  class="ffpImg"
                  style="background: url(/imgs/webview/ffp2.jpg) center/cover no-repeat;"
                >
                </div>
                <span class="ffpIco material-symbols-rounded"
                  >content_paste_search</span
                >
              </div>
              <div class="ffpStepLabel">02</div>
              <div class="ffpHeading">Step 2: Peninjauan & Verifikasi</div>
              <div class="ffpTextBox">
                Tahap evaluasi dan pengecekan untuk memastikan kualitas,
                keakuratan dan validitas informasi atau layanan sebelum
                keputusan final dibuat
              </div>
            </li>
            <li class="glide__slide kredit">
              <div class="ffpImageBox">
                <div
                  class="ffpImg"
                  style="background: url(/imgs/webview/ffp3.png) center/cover no-repeat;"
                >
                </div>
                <span class="ffpIco material-symbols-rounded">check_circle</span
                >
              </div>
              <div class="ffpStepLabel">03</div>
              <div class="ffpHeading">Step 3: Persetujuan kredit</div>
              <div class="ffpTextBox">
                Tahap pemrosesan informasi dan data yang dikumpulkan untuk
                melakukan penilaian, mengevaluasi dan membuat keputusan
                persetujuan. <br />Kemampuan debitur untuk membayar, riwayat
                kredit, dan kepatuhan terhadap persyaratan adalah beberapa
                faktor yang akan dipertimbangkan
              </div>
            </li>
            <li class="glide__slide kredit">
              <div class="ffpImageBox">
                <div
                  class="ffpImg"
                  style="background: url(/imgs/webview/ffp4.jpg) center/cover no-repeat;"
                >
                </div>
                <span class="ffpIco material-symbols-rounded">handshake</span>
              </div>
              <div class="ffpStepLabel">04</div>
              <div class="ffpHeading">Step 4: Pencairan kredit</div>
              <div class="ffpTextBox">
                MyBPR akan mengatur pencairan dana ke rekening debitur.
                Debitur akan menerima jumlah kredit yang disepakati sesuai
                dengan ketentuan yang telah disepakati. <br />Setelah pencairan,
                debitur akan memulai pembayaran kredit sesuai dengan jadwal
                pembayaran yang telah ditentukan.
              </div>
            </li>
          </ul>
        </div>
        <div class="glide__bullets kredit" data-glide-el="controls[nav]">
          <button class="glide__bullet material-symbols-rounded" data-glide-dir="=0"><span class="kreditBulletIndex">publish</span></button>
          <button class="glide__bullet material-symbols-rounded" data-glide-dir="=1"><span class="kreditBulletIndex">content_paste_search</span></button>
          <button class="glide__bullet material-symbols-rounded" data-glide-dir="=2"><span class="kreditBulletIndex">check_circle</span></button>
          <button class="glide__bullet material-symbols-rounded" data-glide-dir="=3"><span class="kreditBulletIndex">handshake</span></button>
        </div>
        <div class="glide__arrows kredit" data-glide-el="controls">
          <button class="glide__arrow glide__arrow--left" data-glide-dir="<"
          ></button>
          <button class="glide__arrow glide__arrow--right" data-glide-dir=">"
          ></button>
        </div>
      </div>
    </div>
    <div class="mbox" id="tabungan_promo">

    </div>
    <GhostSpacer />
  </div>
</div>

<script>
  import Glide from "@glidejs/glide";
  import { Breakpoints } from "@glidejs/glide/dist/glide.modular.esm";
  document.addEventListener("DOMContentLoaded", () => initGlide(true));
  document.addEventListener("astro:load", () => initGlide(true));
  document.addEventListener("astro:after-swap", () => initGlide(true));

  function initGlide(toggleCommand = true) {
    const heroGlide = new Glide(".heroGlide", {
      type: "carousel",
      autoplay: 5000,
      //hoverpause: true,
      animationDuration: 300,
      perView: 1,
      animationTimingFunc: "cubic-bezier(.55,-0.01,0,1)",
      gap: 0,
    });
    heroGlide.on("run", function () {
      const active = document.querySelector(".glide__slide--active");
      if (active) {
        active.classList.remove("fade-in");
      }
    });
    heroGlide.on("move.after", function () {
      // transition is done, trigger fade-in on active slide
      const active = document.querySelector(".glide__slide--active");
      if (active) {
        active.classList.add("fade-in");
      }
    });

    const kreditGlide = new Glide("#flowchart_kredit .kredit_glide", {
      type: "slider",
      //autoplay: 5000,
      hoverpause: true,
      animationDuration: 300,
      perView: 3,
      startAt: 0,
      focusAt: "center",
      animationTimingFunc: "cubic-bezier(.55,-0.01,0,1)",
      gap: 20,
      breakpoints: {
        768: { perView: 1 },
        1024: { perView: 2 },
      },
    });

    if (toggleCommand == true) {
      heroGlide.mount();
      kreditGlide.mount({ Breakpoints });
    } else {
      heroGlide.destroy();
      kreditGlide.destroy();
    }
  }
</script>

