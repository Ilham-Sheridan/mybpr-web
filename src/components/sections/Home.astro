          >
          <button
            class="glide__bullet material-symbols-rounded"
            data-glide-dir="=2"
            ><span class="kreditBulletIndex">check_circle</span></button
          >
          <button
            class="glide__bullet material-symbols-rounded"
            data-glide-dir="=3"
            ><span class="kreditBulletIndex">handshake</span></button
