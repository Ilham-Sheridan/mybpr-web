      </div>
      <div class="tbBox">
        <div class="tbAmount"><span class="tbSymb">≥</span>Rp. 100 Juta</div>
        <div class="tbInterest">3,50%<span class="pa">p.a.</span></div>
      </div>
    </div>
    <hr class="divider" />
    <!-- ############################################################### -->
    <div class="mbox dp" id="deposito_promo">
      <div class="dp_ib">
        <div class="subPseudoImgBox"></div>
        <div class="pseudoImgBox"></div>
        <div class="graphic dp1"></div>
        <div class="graphic dp3"></div>
        <div class="graphic dp2"></div>
        <div class="graphic dp4"></div>
      </div>
      <div class="promo_textbox">
        <span class="product_label">Deposito</span>
        <h1 class="promo_heading">Mulai Deposito</h1>
        <p class="promo_p">
          Ingin investasi yang aman dengan hasil pasti? Deposito kami adalah
          pilihan tepat! Nikmati suku bunga tinggi dan jangka waktu fleksibel
          sesuai kebutuhan.
          <br />Dengan deposito, Investasi tumbuh secara stabil tanpa risiko,
          menjadikannya solusi yang ideal.

          <br /><br />Amankan masa depan finansial dengan cara yang mudah dan
          menguntungkan. Investasikan hari ini, nikmati keuntungannya di
          kemudian hari!
        </p>
      </div>
    </div>
    <div class="dpTitle">Bunga Deposito</div>
    <div class="mbox dp2">
      <div class="dpBox">
        <div class="dpRow">
          <div class="dpDuration"><span class="dpIndex">1</span>1 Bulan</div>
          <div class="dpInterest">4,00%</div>
        </div>
        <div class="dpRow">
          <div class="dpDuration"><span class="dpIndex">2</span>3 Bulan</div>
          <div class="dpInterest">4,25%</div>
        </div>
        <div class="dpRow">
          <div class="dpDuration"><span class="dpIndex">3</span>6 Bulan</div>
          <div class="dpInterest">5,25%</div>
        </div>
        <div class="dpRow">
          <div class="dpDuration"><span class="dpIndex">4</span>12 Bulan</div>
          <div class="dpInterest">5,75%</div>
        </div>
      </div>
    </div>
    <hr class="divider" />
    <!-- ############################################################### -->
    <!-- <GhostSpacer /> -->
  </div>
</div>

<script>
  import Glide from "@glidejs/glide";
  import { Breakpoints } from "@glidejs/glide/dist/glide.modular.esm";

  function initGlide(mount = true) {
    if (!mount) return;

    const heroGlide = new Glide(".heroGlide", {
      type: "carousel",
      autoplay: 5000,
      //hoverpause: true,
      animationDuration: 300,
      perView: 1,
      animationTimingFunc: "cubic-bezier(.55,-0.01,0,1)",
      gap: 0,
    });
    heroGlide.on("run", function () {
      const active = document.querySelector(".glide__slide--active");
      if (active) {
        active.classList.remove("fade-in");
      }
    });
    heroGlide.on("move.after", function () {
      // transition is done, trigger fade-in on active slide
      const active = document.querySelector(".glide__slide--active");
      if (active) {
        active.classList.add("fade-in");
      }
    });

    const kreditGlide = new Glide("#flowchart_kredit .kredit_glide", {
      type: "slider",
      //autoplay: 5000,
      hoverpause: true,
      animationDuration: 300,
      perView: 3,
      startAt: 0,
      focusAt: "center",
      animationTimingFunc: "cubic-bezier(.55,-0.01,0,1)",
      gap: 20,
      breakpoints: {
        767: { perView: 1 },
        1586: { perView: 2 },
      },
    });

    heroGlide.mount();
    kreditGlide.mount({ Breakpoints });
  }

  document.addEventListener("astro:before-preparation", () => initGlide(false));
  document.addEventListener("astro:page-load", () => initGlide(true));
  // document.addEventListener("astro:after-swap", () => initGlide(true));
</script>

<style lang="scss">
  @use "../../styles/mixins" as *;

  // * {
  //   border: 1px solid red;
  // }

  .promo_heading {
    font-size: 6rem;
