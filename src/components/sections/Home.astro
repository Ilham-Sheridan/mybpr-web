---
import "/node_modules/@glidejs/glide/dist/css/glide.core.min.css";
import SlideGen from "../slideGen.astro";
import { slides_dat } from "../../data/slideDat";
import GhostSpacer from "./GhostSpacer.astro";
import "../../styles/componentStyles/tabunganGrid.scss";
import "../../styles/componentStyles/depositoGrid.scss";
import "../../styles/componentStyles/kreditGrid.scss";
import "../../styles/componentStyles/kreditSlider.scss";
---

<!-- <div id="pageLabel">
  <div class="menuMessageBox mini">Welcome!</div>
</div> -->
<div class="herologo">
  <img
    src=`${import.meta.env.BASE_URL}/src/assets/mybpr.svg`
    alt="MyBPR Logo"
  />
</div>

<div class="heroGlide heroCarousel">
  <div class="glide__track" data-glide-el="track">
    <ul class="glide__slides">
      {
        Object.entries(slides_dat).map(([key, slide]) => (
          <SlideGen
            id={slide.id}
            title={slide.title}
            description={slide.description ?? ""}
            subcat={slide.subcat ?? undefined}
            images={slide.images}
            button={slide.button}
          />
        ))
      }
    </ul>
  </div>
  <div class="glide__bullets heroSlideBullets" data-glide-el="controls[nav]">
    {
      Object.entries(slides_dat).map(([key], i) => (
        <button class="glide__bullet" data-glide-dir={`=${i}`}>
          <span class="heroBulletIndex">{i + 1}</span>
        </button>
      ))
    }
  </div>
</div>
<div class="centering">
  <div class="main">
    <hr class="divider" />
    <!-- ############################################################### -->
    <div class="mbox kp1" id="kredit_promo">
      <div class="kp_ib">
        <div class="kp subPseudoImgBox"></div>
        <div class="kp pseudoImgBox"></div>
        <div class="kp kreditBg"></div>
        <div class="kp kreditBanner"></div>
      </div>
      <div class="kp promo_textbox">
        <span class="kp product_label">Kredit</span>
        <h1 class="kp promo_heading">Kredit Express</h1>
        <p class="kp promo_p">
          Butuh dana cepat untuk wujudkan rencana besar? Pinjaman kami hadir
          dengan proses mudah, bunga ringan, dan cicilan fleksibel. Baik untuk
          modal usaha, renovasi rumah, atau kebutuhan mendesak lainnya, kami
          siap memberikan solusi keuangan yang tepat.
          <br /><br />Ajukan pinjaman sekarang dan dapatkan dana tanpa repot!
          Wujudkan impian Anda hari ini!
        </p>
      </div>
    </div>
    <!-- ############################################################### -->
    <div class="mbox kp2" id="kredit_promo">
      <div class="pseudoGrid">
        <div class="kp_ib">
          <div class="kp b2 subPseudoImgBox"></div>
          <div class="kp b2 pseudoImgBox"></div>
          <div class="kp b2 _3m"></div>
          <div class="kp b2 plafond_textbox">
            <span class="plafond-t">Plafond</span>
            <span class="plafond-t">sampai</span>
            <span class="plafond-t">dengan</span>
          </div>
        </div>
        <div class="kp_ib">
          <div class="kp subPseudoImgBox"></div>
          <div class="kp pseudoImgBox"></div>
          <div class="kp _3t5_bolt"></div>
          <div class="kp _3t5_clock"></div>
          <div class="kp _3t5_textbox">
            <span class="_3t5-t">Proses</span>
            <span class="_3t5-t">3-5</span>
            <span class="_3t5-t">Hari Kerja<span class="ast">*</span></span>
          </div>
          <span class="astans">*Setelah data lengkap</span>
        </div>
      </div>
      <!-- <div class="pseudoGrid">
        <div class="bigTextBox">Dengan plafond sampai dengan 3M,</div>
        <div class="bigTextBox">
          proses pencairan Kredit Express cepat, hanya 3 sampai 5 hari kerja
        </div>
      </div> -->
    </div>
    <!-- ############################################################### -->
    <div class="mbox" id="flowchart_kredit">
      <div class="kredit_stringbox">Alur Pengajuan Kredit</div>
      <div class="kredit_glide">
        <div class="glide__track" data-glide-el="track">
          <ul class="glide__slides">
            <li class="glide__slide kredit">
              <div class="ffpImageBox">
                <div
                  class="ffpImg"
                  style="background: url(/mybpr-web/imgs/webview/ffp1.jpg) center/cover no-repeat;"
                >
                </div>
                <span class="ffpIco material-symbols-rounded">publish</span>
              </div>
              <div class="ffpStepLabel">01</div>
              <div class="ffpHeading">Step 1: Pengajuan Kredit</div>
              <div class="ffpTextBox">
                Ingin investasi yang aman dengan hasil pasti? Deposito kami
                adalah pilihan tepat! Nikmati suku bunga tinggi dan jangka waktu
                fleksibel sesuai kebutuhan. <br />Dengan deposito, Investasi
                tumbuh secara stabil tanpa risiko, menjadikannya solusi yang
                ideal.

                <br /><br />Amankan masa depan finansial dengan cara yang mudah
                dan menguntungkan. Investasikan hari ini, nikmati keuntungannya
                di kemudian hari!
              </div>
            </li>
            <li class="glide__slide kredit">
              <div class="ffpImageBox">
                <div
                  class="ffpImg"
                  style="background: url(/mybpr-web/imgs/webview/ffp2.jpg) center/cover no-repeat;"
                >
                </div>
                <span class="ffpIco material-symbols-rounded"
