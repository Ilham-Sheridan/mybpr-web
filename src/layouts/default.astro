---
import { ClientRouter, slide, fade } from "astro:transitions";
import favico from "../assets/mybpr.svg";
import QuirkyLoad from "../components/utils/quirkyLoad.astro";
import DynamicNav from "../components/dynamicNav.astro";

interface Props {
  url?: string;
  title?: string;
  description?: string;
  thumb?: string;
}
const { thumb, url, title, description } = Astro.props;
---

<!doctype html>
<html lang="en" transition:name="root" transition:animate="none">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href={favico.src} />

    <!-- OG -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url ? url : "https://mybpr.com"} />
    <meta property="og:title" content={title ? title : "PT. BPR MULIA YUGANTA INDONESIA - PT. BPR Mulia Yuganta Indonesia"} />
    <meta property="og:description" content={description ? description : "PT. BPR MULIA YUGANTA INDONESIA - PT. BPR Mulia Yuganta Indonesia"} />
    <meta
      property="og:image"
      content={thumb ? `${import.meta.env.SITE}${thumb}` : `${import.meta.env.SITE}/content/thumb/thumb.jpg`}
    />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={url ? url : "https://mybpr.com"} />
    <meta property="twitter:title" content={title ? title : "PT. BPR MULIA YUGANTA INDONESIA - PT. BPR Mulia Yuganta Indonesia"} />
    <meta property="twitter:description" content={description ? description : "PT. BPR MULIA YUGANTA INDONESIA - PT. BPR Mulia Yuganta Indonesia"} />
    <meta
      property="twitter:image"
      content={thumb ? `${import.meta.env.SITE}${thumb}` : `${import.meta.env.SITE}/content/thumb/thumb.jpg`}
    />

    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=check_circle,content_paste_search,handshake,publish,send_money" />
    <title>PT. BPR MULIA YUGANTA INDONESIA - PT. BPR Mulia Yuganta Indonesia</title>
    <ClientRouter />
  </head>
  <body>
    <DynamicNav />
    <QuirkyLoad />

    <div transition:animate={fade({ duration: ".5s" })}>
      <slot />
    </div>

    <div class="endOfPage">
      <hr class="end" />
    </div>
    <div class="footer">
      <div class="flexbox1">
        <div class="socials">
          <a href="https://bsky.app/profile/potto.bsky.social" target="_blank">
            <div class="socicon bsky"></div>
          </a>
          <a href="https://twitter.com/Potto2292" target="_blank">
            <div class="socicon twt"></div>
          </a>
        </div>
        <span class="copyright">© 2026 By PT. BPR MULIA YUGANTA INDONESIA</span>
        <a href="tos" class="tosPageLink"><span>Terms of Service</span></a>
      </div>
    </div>
  </body>
</html>
